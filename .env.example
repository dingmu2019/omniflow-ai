# ==========================================
# 核心通信配置
# ==========================================
# 1. 申请地址：https://dashboard.daily.co/ (免费 10000 分钟/月)
DAILY_API_KEY=your_daily_api_key_here

# 2. Twilio 配置 (PSTN 电话接入，后续用到)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ==========================================
# AI 引擎配置
# ==========================================
# OpenAI 官方或支持 Realtime WebSocket 的代理商
OPENAI_API_KEY=your_openai_api_key
# 如果使用第三方代理，需确保代理商支持 wss:// (Realtime API) 协议
# 示例: wss://api.proxy-domain.com/v1/realtime (注释掉则默认使用官方)
# OPENAI_BASE_URL=wss://api.proxy-domain.com/v1/realtime

# Gemini 备用方案
GEMINI_API_KEY=your_gemini_api_key
